generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("POSTGRES_PRISMA_URL")
}

model Cat {
    id           String @id @default(uuid())
    species         String @unique @db.VarChar(255)
    attributes Attributes[]
    strength     Int
    defense      Int
    magicDefense Int
    intelligence Int
    speed        Int
    health       Int
    mana         Int

    users UserCat[]

    createdAt DateTime @default(now())
    updatedAt DateTime @default(now())

    @@map("cats")
}

enum Attributes {
    AQUATIC
    MISCHIEVOUS
    SPEEDY
}

model UserCat {
    user   User    @relation(fields: [userId], references: [id])
    userId String
    cat    Cat     @relation(fields: [catId], references: [id])
    catId  String
    name   String?

    nestId String?
    nest Nest? @relation(fields: [nestId], references: [id])

    @@id([userId, catId])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Egg {
    id String @id @default(uuid())
    nest Nest?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Hatchery {
    id String @id @default(uuid())

    treeId String @unique
    tree Tree @relation(fields: [treeId], references: [id])

    nests Nest[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Nest {
    id String @id @default(uuid())
    hatcheryId String
    hatchery Hatchery @relation(fields: [hatcheryId], references: [id])

    eggId String? @unique
    egg Egg? @relation(fields: [eggId], references: [id])

    hatchers UserCat[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Tree {
    id        String   @id @default(uuid())
    hasgarden Boolean? @default(false)
    name      String?  @db.VarChar(255)
    users     User[]
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    hatchery Hatchery?

    @@map("trees")
}

model User {
    id        String   @id @default(uuid())
    username  String   @unique @db.VarChar(30)
    email     String   @unique @db.VarChar(255)
    password  String   @db.VarChar(255)
    tree      Tree?    @relation(fields: [treeId], references: [id])
    treeId    String?
    roles     Role[]   @default([USER])
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    cats UserCat[]
    inventory UserItems[]

    @@map("users")
}

enum Role {
    USER
    ADMIN
}

model Item {
    id String @id @default(uuid())
    type String
    description String
    users UserItems[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model UserItems {
    userId String
    itemId String
    user User @relation(fields: [userId], references: [id])
    item Item @relation(fields: [itemId], references: [id])

    quantity Int @default(0)

    @@id([userId, itemId])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}